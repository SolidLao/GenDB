    "topk"
  ],
  "join_order": [
    {
      "build": "sub(filtered: fy=2023)",
      "probe": "pre(stmt='IS' via pre_stmt_hash)",
      "type": "semi",
      "strategy": "hash_join",
      "build_cardinality": 26612,
      "notes": "Use fy-filtered adsh set to prune pre stmt postings before hash build."
    },
    {
      "build": "pre(filtered: stmt='IS' AND adsh in sub_fy2023)",
      "probe": "num via num_adsh_fk_hash postings (adsh in sub_fy2023)",
      "type": "inner",
      "strategy": "hash_join",
      "build_cardinality": 575000,
      "notes": "Build compact hash map on (adsh,tag,version)->plabel list; probe from num postings and apply USD/non-null predicates before aggregation."
    }
  ],
  "filters": [
