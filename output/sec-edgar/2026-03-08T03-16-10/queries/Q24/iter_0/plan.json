{
  "query_id": "Q24",
  "pipeline": [
    "prune_num_blocks",
    "scan_num_filtered",
    "anti_join_pre",
    "aggregate",
    "having",
    "topk"
  ],
  "join_order": [
    {
      "build": "pre(adsh,tag,version sorted index)",
      "probe": "num(filtered)",
      "type": "anti",
      "strategy": "index_nested_loop",
      "build_cardinality": 9600799,
      "notes": "Binary-search pre/indexes/adsh_tag_version.rowids.bin for each surviving num key; expected probe cardinality is 0 after zone-map pruning."
    }
  ],
  "filters": [
    {
      "table": "num",
      "predicate": "uom = 'USD'",
      "selectivity": 0.1
    },
    {
      "table": "num",
      "predicate": "ddate BETWEEN 19358 AND 19722",
      "selectivity": 0.0
    },
    {
      "table": "num",
      "predicate": "value IS NOT NULL",
      "selectivity": 1.0
    }
  ],
  "data_structures": {
    "dim_filter": "bitset(395)",
    "fact_join": "pre_built_index",
    "aggregation": "compact_hash_map"
  },
  "parallelism": {
    "strategy": "morsel_driven",
    "threads": "auto(nproc)"
  },
  "indexes": [
    {
      "index": "num/indexes/uom.zone_map.bin",
      "purpose": "skip_blocks"
    },
    {
      "index": "num/indexes/ddate.zone_map.bin",
      "purpose": "skip_blocks"
    },
    {
      "index": "pre/indexes/adsh_tag_version.rowids.bin",
      "purpose": "join_lookup"
    }
  ],
  "aggregation": "hash_group_by",
  "output": {
    "order_by": [
      "cnt DESC"
    ],
    "limit": 100
  },
  "execution_target": "cpp"
}
