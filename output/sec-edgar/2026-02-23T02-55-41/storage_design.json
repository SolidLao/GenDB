        {"name": "filed",     "cpp_type": "int32_t", "semantic_type": "integer",             "encoding": "YYYYMMDD integer"},
        {"name": "prevrpt",   "cpp_type": "int32_t", "semantic_type": "integer",             "encoding": "0/1 flag"},
        {"name": "nciks",     "cpp_type": "int32_t", "semantic_type": "integer",             "encoding": "direct"},
        {"name": "afs",       "cpp_type": "int32_t", "semantic_type": "dict_local",          "encoding": "per-table dict; sub/afs_dict.txt"},
        {"name": "wksi",      "cpp_type": "int32_t", "semantic_type": "integer",             "encoding": "0/1 flag"},
        {"name": "fye",       "cpp_type": "int32_t", "semantic_type": "dict_local",          "encoding": "per-table dict; sub/fye_dict.txt"}
