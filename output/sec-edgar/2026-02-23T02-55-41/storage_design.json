        {"name": "name",      "cpp_type": "int32_t", "semantic_type": "dict_local",          "encoding": "per-table dict; sub/name_dict.txt"},
        {"name": "sic",       "cpp_type": "int32_t", "semantic_type": "integer",             "encoding": "direct"},
        {"name": "countryba", "cpp_type": "int32_t", "semantic_type": "dict_local",          "encoding": "per-table dict; sub/countryba_dict.txt"},
        {"name": "stprba",    "cpp_type": "int32_t", "semantic_type": "dict_local",          "encoding": "per-table dict; sub/stprba_dict.txt"},
