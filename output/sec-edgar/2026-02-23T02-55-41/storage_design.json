      "estimated_rows": "39401761",
      "indexes": [
        {"name": "ddate_zone_map", "type": "zone_map", "columns": ["ddate"],
         "file": "num/indexes/ddate_zone_map.bin",
         "layout": "[uint32_t num_blocks][{int32_t min, int32_t max, uint32_t block_size}...]",
         "note": "YYYYMMDD integer; Q24 uses ddate BETWEEN 20230101 AND 20231231"}
      ]
    },
    "pre": {
      "columns": [
        {"name": "adsh",    "cpp_type": "int32_t", "semantic_type": "dict_shared_adsh",   "encoding": "shared adsh dict"},
        {"name": "report",  "cpp_type": "int32_t", "semantic_type": "integer",            "encoding": "direct"},
        {"name": "line",    "cpp_type": "int32_t", "semantic_type": "integer",            "encoding": "direct"},
        {"name": "stmt",    "cpp_type": "int32_t", "semantic_type": "dict_local",         "encoding": "per-table dict; pre/stmt_dict.txt; 8 distinct"},
        {"name": "inpth",   "cpp_type": "int32_t", "semantic_type": "integer",            "encoding": "0/1 flag"},
        {"name": "rfile",   "cpp_type": "int32_t", "semantic_type": "dict_local",         "encoding": "per-table dict; pre/rfile_dict.txt; 2 distinct (H/X)"},
        {"name": "tag",     "cpp_type": "int32_t", "semantic_type": "dict_shared_tag",    "encoding": "shared tag dict"},
        {"name": "version", "cpp_type": "int32_t", "semantic_type": "dict_shared_version","encoding": "shared version dict"},
        {"name": "plabel",  "cpp_type": "int32_t", "semantic_type": "dict_local",         "encoding": "per-table dict; pre/plabel_dict.txt"},
