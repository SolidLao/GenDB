         "note": "(tag_code,ver_code) -> tag_row_index; used for num->tag join in Q4"}
      ]
    },
    "num": {
      "columns": [
        {"name": "adsh",    "cpp_type": "int32_t", "semantic_type": "dict_shared_adsh",   "encoding": "shared adsh dict; adsh_code == sub_row_index"},
        {"name": "tag",     "cpp_type": "int32_t", "semantic_type": "dict_shared_tag",    "encoding": "shared tag dict"},
