        {"name": "ddate",   "cpp_type": "int32_t", "semantic_type": "integer",            "encoding": "YYYYMMDD integer direct (NOT epoch days); e.g. 20230101"},
        {"name": "qtrs",    "cpp_type": "int32_t", "semantic_type": "integer",            "encoding": "direct"},
        {"name": "uom",     "cpp_type": "int32_t", "semantic_type": "dict_local",         "encoding": "per-table dict; num/uom_dict.txt; ~25 distinct"},
        {"name": "coreg",   "cpp_type": "int32_t", "semantic_type": "dict_local",         "encoding": "per-table dict; num/coreg_dict.txt; empty string = code 0"},
