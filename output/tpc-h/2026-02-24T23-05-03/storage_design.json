{
  "persistent_storage": { "format": "binary_columnar", "base_dir_name": "sf10.gendb" },
  "tables": {
    "lineitem": {
      "columns": [
        {"name": "l_orderkey",      "cpp_type": "int32_t", "semantic_type": "key",         "encoding": "direct"},
        {"name": "l_partkey",       "cpp_type": "int32_t", "semantic_type": "foreign_key", "encoding": "direct"},
        {"name": "l_suppkey",       "cpp_type": "int32_t", "semantic_type": "foreign_key", "encoding": "direct"},
        {"name": "l_quantity",      "cpp_type": "double",  "semantic_type": "measure",     "encoding": "double"},
        {"name": "l_extendedprice", "cpp_type": "double",  "semantic_type": "measure",     "encoding": "double",
         "note": "max individual value ~104,949. Well below 10^13. double precision sufficient. C29 not triggered."},
        {"name": "l_discount",      "cpp_type": "double",  "semantic_type": "measure",     "encoding": "double"},
        {"name": "l_tax",           "cpp_type": "double",  "semantic_type": "measure",     "encoding": "double"},
        {"name": "l_returnflag",    "cpp_type": "int16_t", "semantic_type": "category",    "encoding": "dict",
         "dict_file": "lineitem/l_returnflag_dict.txt", "approx_distinct": 3},
        {"name": "l_linestatus",    "cpp_type": "int16_t", "semantic_type": "category",    "encoding": "dict",
         "dict_file": "lineitem/l_linestatus_dict.txt", "approx_distinct": 2},
        {"name": "l_shipdate",      "cpp_type": "int32_t", "semantic_type": "date",        "encoding": "days_since_epoch_1970",
         "note": "Values > 3000. min=1992-01-02, max=1998-12-01."}
      ],
      "file_format": {
        "filename": "lineitem.tbl", "delimiter": "|",
        "column_order": ["l_orderkey","l_partkey","l_suppkey","l_linenumber","l_quantity",
                         "l_extendedprice","l_discount","l_tax","l_returnflag","l_linestatus",
                         "l_shipdate","l_commitdate","l_receiptdate","l_shipinstruct","l_shipmode","l_comment"]
      },
      "sort_order": [], "block_size": 65536, "estimated_rows": "59986052",
      "indexes": [
        {
          "name": "l_shipdate_zone_map", "type": "zone_map", "columns": ["l_shipdate"],
          "file": "lineitem/indexes/l_shipdate_zone_map.bin", "block_size": 65536,
          "format": "[uint32_t num_blocks][per_block: int32_t min, int32_t max, uint32_t count]",
          "note": "Useful for Q1 (<=date) and Q6 (BETWEEN). Q3 l_shipdate > date: selectivity 0.55 so marginal."
        }
      ]
    },
    "orders": {
      "columns": [
        {"name": "o_orderkey",     "cpp_type": "int32_t", "semantic_type": "key",         "encoding": "direct"},
        {"name": "o_custkey",      "cpp_type": "int32_t", "semantic_type": "foreign_key", "encoding": "direct"},
        {"name": "o_orderdate",    "cpp_type": "int32_t", "semantic_type": "date",        "encoding": "days_since_epoch_1970",
         "note": "Values > 3000. min=1992-01-01, max=1998-12-31."},
        {"name": "o_shippriority", "cpp_type": "int32_t", "semantic_type": "attribute",   "encoding": "direct"},
        {"name": "o_totalprice",   "cpp_type": "double",  "semantic_type": "measure",     "encoding": "double"}
      ],
      "file_format": {
        "filename": "orders.tbl", "delimiter": "|",
        "column_order": ["o_orderkey","o_custkey","o_orderstatus","o_totalprice","o_orderdate",
                         "o_orderpriority","o_clerk","o_shippriority","o_comment"]
      },
      "sort_order": [], "block_size": 65536, "estimated_rows": "15000000",
      "indexes": [
        {
          "name": "orders_pk_hash", "type": "hash", "columns": ["o_orderkey"],
          "file": "orders/indexes/orders_pk_hash.bin",
          "layout": "[uint32_t cap][OSlot[cap]] where OSlot={int32_t key=INT32_MIN_sentinel; uint32_t row_idx}",
          "hash_fn": "((uint32_t)key * 2654435761u) & mask",
          "cap": "next_power_of_2(15000000 * 2) = 33554432",
          "slot_bytes": 8, "file_size_bytes": "4 + 33554432*8 = 268435460"
        },
        {
          "name": "o_orderdate_zone_map", "type": "zone_map", "columns": ["o_orderdate"],
          "file": "orders/indexes/o_orderdate_zone_map.bin", "block_size": 65536,
          "format": "[uint32_t num_blocks][per_block: int32_t min, int32_t max, uint32_t count]",
          "note": "Used in Q3 (< 1995-03-15 = day 9205), Q9 (EXTRACT YEAR)."
        }
      ]
    },
    "customer": {
      "columns": [
        {"name": "c_custkey",    "cpp_type": "int32_t", "semantic_type": "key",         "encoding": "direct"},
        {"name": "c_nationkey",  "cpp_type": "int32_t", "semantic_type": "foreign_key", "encoding": "direct"},
        {"name": "c_mktsegment", "cpp_type": "int16_t", "semantic_type": "category",    "encoding": "dict",
         "dict_file": "customer/c_mktsegment_dict.txt", "approx_distinct": 5}
      ],
      "file_format": {
        "filename": "customer.tbl", "delimiter": "|",
        "column_order": ["c_custkey","c_name","c_address","c_nationkey","c_phone","c_acctbal","c_mktsegment","c_comment"]
      },
      "sort_order": [], "block_size": 65536, "estimated_rows": "1500000",
      "notes": "c_name NOT stored in binary — Q18 reconstructs as sprintf('Customer#%09d', c_custkey)",
      "indexes": [
        {
          "name": "customer_pk_hash", "type": "hash", "columns": ["c_custkey"],
          "file": "customer/indexes/customer_pk_hash.bin",
          "layout": "[uint32_t cap][CSlot[cap]] where CSlot={int32_t key=INT32_MIN_sentinel; uint32_t row_idx}",
          "hash_fn": "((uint32_t)key * 2654435761u) & mask",
          "cap": "next_power_of_2(1500000 * 2) = 4194304",
          "slot_bytes": 8, "file_size_bytes": "4 + 4194304*8 = 33554436"
        }
      ]
    },
    "part": {
      "columns": [
        {"name": "p_partkey", "cpp_type": "int32_t", "semantic_type": "key",    "encoding": "direct"},
        {"name": "p_name",    "cpp_type": "int32_t", "semantic_type": "string", "encoding": "dict_int32",
         "dict_file": "part/p_name_dict.txt", "approx_distinct": 2000000,
         "note": "int32_t code — 2M distinct values exceed int16_t range (32767). Q9 loads dict and scans for 'green' substring."}
      ],
      "file_format": {
        "filename": "part.tbl", "delimiter": "|",
        "column_order": ["p_partkey","p_name","p_mfgr","p_brand","p_type","p_size","p_container","p_retailprice","p_comment"]
      },
      "sort_order": [], "block_size": 65536, "estimated_rows": "2000000",
      "indexes": []
    },
    "partsupp": {
      "columns": [
        {"name": "ps_partkey",    "cpp_type": "int32_t", "semantic_type": "key",     "encoding": "direct"},
        {"name": "ps_suppkey",    "cpp_type": "int32_t", "semantic_type": "key",     "encoding": "direct"},
        {"name": "ps_supplycost", "cpp_type": "double",  "semantic_type": "measure", "encoding": "double"}
      ],
      "file_format": {
        "filename": "partsupp.tbl", "delimiter": "|",
        "column_order": ["ps_partkey","ps_suppkey","ps_availqty","ps_supplycost","ps_comment"]
      },
      "sort_order": [], "block_size": 65536, "estimated_rows": "8000000",
      "indexes": [
        {
          "name": "partsupp_pk_hash", "type": "hash", "columns": ["ps_partkey","ps_suppkey"],
          "file": "partsupp/indexes/partsupp_pk_hash.bin",
          "layout": "[uint32_t cap][PSSlot[cap]] where PSSlot={int32_t partkey=INT32_MIN_sentinel; int32_t suppkey; uint32_t row_idx}",
          "hash_fn": "(uint32_t)(((uint64_t)(uint32_t)partkey << 32 | (uint32_t)suppkey) * 11400714819323198485ull >> 32) & mask",
          "cap": "next_power_of_2(8000000 * 2) = 16777216",
          "slot_bytes": 12, "file_size_bytes": "4 + 16777216*12 = 201326596"
        }
      ]
    },
    "supplier": {
      "columns": [
        {"name": "s_suppkey",   "cpp_type": "int32_t", "semantic_type": "key",         "encoding": "direct"},
        {"name": "s_nationkey", "cpp_type": "int32_t", "semantic_type": "foreign_key", "encoding": "direct"}
      ],
      "file_format": {
        "filename": "supplier.tbl", "delimiter": "|",
        "column_order": ["s_suppkey","s_name","s_address","s_nationkey","s_phone","s_acctbal","s_comment"]
      },
      "sort_order": [], "block_size": 65536, "estimated_rows": "100000",
      "indexes": [
        {
          "name": "supplier_pk_hash", "type": "hash", "columns": ["s_suppkey"],
          "file": "supplier/indexes/supplier_pk_hash.bin",
          "layout": "[uint32_t cap][SSlot[cap]] where SSlot={int32_t key=INT32_MIN_sentinel; uint32_t row_idx}",
          "hash_fn": "((uint32_t)key * 2654435761u) & mask",
          "cap": "next_power_of_2(100000 * 2) = 262144",
          "slot_bytes": 8, "file_size_bytes": "4 + 262144*8 = 2097156"
        }
      ]
    },
    "nation": {
      "columns": [
        {"name": "n_nationkey", "cpp_type": "int32_t", "semantic_type": "key",    "encoding": "direct"},
        {"name": "n_name",      "cpp_type": "int16_t", "semantic_type": "string", "encoding": "dict",
         "dict_file": "nation/n_name_dict.txt", "approx_distinct": 25}
      ],
      "file_format": {
        "filename": "nation.tbl", "delimiter": "|",
        "column_order": ["n_nationkey","n_name","n_regionkey","n_comment"]
      },
      "sort_order": [], "block_size": 65536, "estimated_rows": "25",
      "indexes": []
    },
    "region": {
      "columns": [
        {"name": "r_regionkey", "cpp_type": "int32_t", "semantic_type": "key",    "encoding": "direct"},
        {"name": "r_name",      "cpp_type": "int16_t", "semantic_type": "string", "encoding": "dict",
         "dict_file": "region/r_name_dict.txt", "approx_distinct": 5}
      ],
      "file_format": {
        "filename": "region.tbl", "delimiter": "|",
        "column_order": ["r_regionkey","r_name","r_comment"]
      },
      "sort_order": [], "block_size": 65536, "estimated_rows": "5",
      "indexes": []
    }
  },
  "type_mappings": { "INTEGER": "int32_t", "DECIMAL": "double", "DATE": "int32_t" },
  "date_encoding": "days_since_epoch_1970",
  "decimal_encoding": "double — individual values max ~105K, well below 10^13 threshold; double precision sufficient",
  "hardware_config": {
    "cpu_cores": "64",
    "l3_cache_mb": "44",
    "disk_type": "hdd",
    "total_memory_gb": "376",
    "avx512": true
  },
  "index_design_notes": {
    "zone_maps": "l_shipdate (Q1/Q6/Q3 range filters), o_orderdate (Q3/Q9 range filters)",
    "hash_indexes": "orders_pk_hash (Q3/Q18 join), customer_pk_hash (Q3/Q18 join), supplier_pk_hash (Q9 join), partsupp_pk_hash (Q9 composite join)",
    "not_indexed": "lineitem (too large for PK hash; accessed sequentially), part (Q9 filters by p_name dict scan, no equality join needed), nation/region (tiny — linear scan)"
  }
}
