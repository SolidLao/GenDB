    },
    {
      "table": "lineitem", "column": "l_quantity", "operator": "<",
      "value": "24", "selectivity": 0.460, "query": "Q6"
    },
    {
      "table": "lineitem", "column": "combined Q6 filters", "operator": "AND",
      "selectivity": 0.020, "query": "Q6"
    },
    {
      "table": "customer", "column": "c_mktsegment", "operator": "=",
