    },
    {
      "table": "orders", "column": "o_orderdate", "operator": "<",
      "value": "1995-03-15", "selectivity": 0.486, "query": "Q3"
    },
    {
      "table": "lineitem", "column": "l_shipdate", "operator": ">",
      "value": "1995-03-15", "selectivity": 0.540, "query": "Q3"
    },
    {
      "table": "part", "column": "p_name", "operator": "LIKE '%green%'",
      "selectivity": 0.054, "query": "Q9"
    },
    {
      "table": "lineitem", "column": "l_orderkey (subquery)", "operator": "IN",
      "selectivity": 0.0000416, "query": "Q18",
      "note": "624 out of 15M orders have sum(l_quantity)>300"
    }
  ],
  "aggregations": [
    {
      "group_by": ["l_returnflag", "l_linestatus"],
      "functions": ["SUM(l_quantity)", "SUM(l_extendedprice)", "SUM(l_extendedprice*(1-l_discount))", "SUM(l_extendedprice*(1-l_discount)*(1+l_tax))", "AVG(l_quantity)", "AVG(l_extendedprice)", "AVG(l_discount)", "COUNT(*)"],
      "query": "Q1", "estimated_groups": "4"
    },
    {
      "group_by": ["l_orderkey", "o_orderdate", "o_shippriority"],
      "functions": ["SUM(l_extendedprice*(1-l_discount))"],
      "query": "Q3", "estimated_groups": "~3500000 (post-filter)"
    },
    {
      "group_by": [],
      "functions": ["SUM(l_extendedprice*l_discount)"],
      "query": "Q6", "estimated_groups": "1"
    },
    {
      "group_by": ["n_name", "EXTRACT(YEAR FROM o_orderdate)"],
      "functions": ["SUM(l_extendedprice*(1-l_discount)-ps_supplycost*l_quantity)"],
      "query": "Q9", "estimated_groups": "175"
    },
    {
      "group_by": ["l_orderkey"],
      "functions": ["SUM(l_quantity)"],
      "query": "Q18-subquery", "estimated_groups": "15000000"
    },
    {
      "group_by": ["c_name", "c_custkey", "o_orderkey", "o_orderdate", "o_totalprice"],
      "functions": ["SUM(l_quantity)"],
      "query": "Q18", "estimated_groups": "~624 (post-subquery filter)"
    }
