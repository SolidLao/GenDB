  "ordering": [
    { "columns": ["l_returnflag ASC", "l_linestatus ASC"], "limit": null, "query": "Q1" },
    { "columns": ["revenue DESC", "o_orderdate ASC"], "limit": 10, "query": "Q3" },
    { "columns": ["nation ASC", "o_year DESC"], "limit": null, "query": "Q9" },
