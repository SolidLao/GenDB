        { "index": "orders_custkey_idx", "operation": "range_scan" },
        { "index": "lineitem_orderkey_idx", "operation": "range_scan" },
        { "index": "orders_orderdate_zonemap", "operation": "block_skip" },
        { "index": "lineitem_shipdate_zonemap", "operation": "block_skip" }
      ],
      "predicate_pushdown": ["c_mktsegment = 'BUILDING'", "o_orderdate < '1995-03-15'", "l_shipdate > '1995-03-15'"],
      "parallel_scan": true
    },
    "Q6": {
      "tables_accessed": ["lineitem"],
      "columns_needed": ["l_shipdate", "l_discount", "l_quantity", "l_extendedprice"],
      "index_usage": [
        { "index": "lineitem_shipdate_zonemap", "operation": "block_skip" },
        { "index": "lineitem_discount_zonemap", "operation": "block_skip" },
        { "index": "lineitem_quantity_zonemap", "operation": "block_skip" }
      ],
      "predicate_pushdown": ["l_shipdate >= '1994-01-01'", "l_shipdate < '1995-01-01'", "l_discount >= 0.05", "l_discount <= 0.07", "l_quantity < 24"],
      "parallel_scan": true
    }
