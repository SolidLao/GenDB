  "type_mappings": {
    "INTEGER":     "int32_t",
    "DECIMAL":     "double",
    "DATE":        "int32_t",
    "CHAR_single": "int8_t (raw cast)",
    "CHAR_multi":  "varlen (offset_data)",
    "VARCHAR":     "varlen (offset_data)"
  },
  "date_encoding": "days_since_epoch_1970 (Howard Hinnant days_from_civil; 1970-01-01=0)",
  "varlen_encoding": {
    "offsets_file": "<col>.offsets — int32_t[N+1]; offsets[i]=byte start of row i in .data; len=offsets[i+1]-offsets[i]",
    "data_file":    "<col>.data    — concatenated raw bytes, no null terminators"
  },
  "dict_encoding": {
    "codes_file": "<col>.bin  — int8_t[N]; code for each row",
    "dict_file":  "<col>.dict — text file; line i (0-indexed) is the string for code i"
  },
  "hash_index_formats": {
    "hash_pk": {
      "description": "Open-addressing linear-probe hash; unique key -> row_id",
      "header": "uint64_t num_entries; uint64_t bucket_count",
      "buckets": "{int32_t key; int32_t row_id}[bucket_count]",
      "empty_sentinel": "key == INT32_MIN (-2147483648)",
      "hash_fn": "(uint32_t(key) * 2654435761u) % bucket_count",
      "load_factor": 0.6
    },
    "hash_pk_composite": {
      "description": "Open-addressing for int64 composite key -> row_id",
      "header": "uint64_t num_entries; uint64_t bucket_count",
      "buckets": "{int64_t key; int32_t row_id; int32_t pad}[bucket_count]",
      "empty_sentinel": "key == INT64_MIN",
      "key_formula": "(int64_t(ps_partkey) << 32) | uint32_t(ps_suppkey)",
      "hash_fn": "splitmix64(key) % bucket_count",
      "load_factor": 0.6
    },
    "fk_sorted": {
      "description": "Sorted (key, row_id) pairs for 1:many FK lookups; binary search by key",
      "header": "uint64_t num_pairs",
      "pairs": "{int32_t key; int32_t row_id}[num_pairs] — sorted ascending by key"
    },
    "zone_map": {
      "description": "Per-block min/max for sorted date column; enables I/O block skipping",
      "header": "uint64_t n_blocks",
      "entries": "{int32_t min_val; int32_t max_val}[n_blocks]",
      "block_size": 100000
    }
  },
  "hardware_config": {
    "cpu_cores": "64",
    "l3_cache_mb": "44",
    "disk_type": "hdd",
    "total_memory_gb": "376",
    "simd": "AVX-512"
  }
}
