  "type_mappings": {
    "INTEGER": "int32_t",
    "DECIMAL": "double",
    "DATE":    "int32_t",
    "CHAR(1)": "int8_t (ASCII value direct)",
    "CHAR/VARCHAR low-cardinality": "int16_t (dictionary encoded)",
    "VARCHAR high-cardinality": "char[N] fixed-width or skipped"
  },
  "_note_decimal": "DECIMAL stored as double. TPC-H workload requires SUM/AVG aggregations without cent-exact compliance. double gives <$1 error on SF10-scale totals (15-16 significant digits). No scale_factor needed.",
  "date_encoding": "days_since_epoch_1970",
  "hardware_config": {
    "cpu_cores": "64",
    "l3_cache_mb": "44",
    "disk_type": "hdd",
    "total_memory_gb": "376",
    "simd": "avx512f,avx512bw,avx512vl"
  },
  "summary": "Binary columnar TPC-H SF10. lineitem (60M rows) sorted by l_shipdate → zone maps skip ~85% blocks for Q6 (15% selectivity). orders (15M rows) sorted by o_orderdate for Q3. Dictionary-encoded low-cardinality strings (l_returnflag/l_linestatus stored as int8_t char). p_name as char[56] for LIKE scan. Multi-value hash on lineitem.l_orderkey; unique hashes on all PK/join columns except nation (25 rows, linear scan). 64-thread parallel ingestion + OpenMP index construction."
}
