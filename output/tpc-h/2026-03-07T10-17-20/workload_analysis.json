    { "group_by": ["l_orderkey","o_orderdate","o_shippriority"], "functions": ["SUM(l_extendedprice*(1-l_discount))"], "query": "Q3", "estimated_groups": "~3000000" },
    { "group_by": [], "functions": ["SUM(l_extendedprice*l_discount)"], "query": "Q6", "estimated_groups": "1" },
    { "group_by": ["nation","o_year"], "functions": ["SUM(l_extendedprice*(1-l_discount)-ps_supplycost*l_quantity)"], "query": "Q9", "estimated_groups": "175" },
    { "group_by": ["l_orderkey"], "functions": ["SUM(l_quantity)"], "query": "Q18-subquery", "estimated_groups": "~15000000", "having": "SUM(l_quantity)>300" },
    { "group_by": ["c_name","c_custkey","o_orderkey","o_orderdate","o_totalprice"], "functions": ["SUM(l_quantity)"], "query": "Q18", "estimated_groups": "~few_thousand" }
