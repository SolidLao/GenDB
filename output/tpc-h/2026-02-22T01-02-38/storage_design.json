  "type_mappings": {
    "INTEGER": "int32_t",
    "DECIMAL": "double",
    "DATE":    "int32_t",
    "CHAR(1)": "int8_t (raw ASCII char value)",
    "CHAR(N)": "char[N+1] fixed-width or uint8_t dictionary",
    "VARCHAR": "char[max_len+1] fixed-width"
  },
  "_note_decimal": "DECIMAL stored as double. TPC-H analytics tolerates floating-point error; no cent-exact requirement.",
  "date_encoding": "days_since_epoch_1970 (1970-01-01 = 0). Self-test: parse_date(1970,1,1)=0.",
  "hash_index_format": {
    "single_key": "uint32_t ht_size | uint32_t num_pos | ht_size x {int32_t key, uint32_t offset, uint32_t count} | num_pos x uint32_t row_idx",
    "composite_key": "uint32_t ht_size | uint32_t num_pos | ht_size x {int64_t key, uint32_t offset, uint32_t count} | num_pos x uint32_t row_idx",
    "empty_slot_sentinel": "key = INT32_MIN or INT64_MIN",
    "hash_fn": "multiply-shift: (uint64_t)(uint32_t)key * 0x9E3779B97F4A7C15ULL >> 32, masked to (ht_size-1)",
    "load_factor": "<=0.5 (ht_size = next_pow2(2*num_unique_keys))"
  },
  "zone_map_format": {
    "int32_date": "[uint32_t num_blocks][num_blocks x {int32_t min, int32_t max}]",
    "double":     "[uint32_t num_blocks][num_blocks x {double min, double max}]",
    "block_size": 100000,
    "row_offset": "row index (not byte offset): block b covers rows [b*100000 .. (b+1)*100000)"
  },
  "hardware_config": {"cpu_cores": "64", "l3_cache_mb": "44", "disk_type": "hdd", "total_memory_gb": "376"},
  "summary": "TPC-H SF10 columnar binary storage. lineitem (60M rows) sorted by l_shipdate for maximally effective zone map pruning on Q1/Q3/Q6. orders (15M rows) sorted by o_orderdate. DECIMAL as double. CHAR(1) as int8_t ASCII. Low-cardinality strings dictionary-encoded (uint8_t). Fixed-width char[] for output strings. Zone maps on sorted date columns; hash indexes for all join columns. Indexes written to sf10.gendb/indexes/."
}
