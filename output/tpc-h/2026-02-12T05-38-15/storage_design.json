  "io_strategies": {
    "Q1": {
      "tables_accessed": ["lineitem"],
      "columns_needed": [
        "lineitem.l_shipdate",
        "lineitem.l_returnflag",
        "lineitem.l_linestatus",
        "lineitem.l_quantity",
        "lineitem.l_extendedprice",
        "lineitem.l_discount",
        "lineitem.l_tax"
      ],
      "index_usage": [
        {
          "index": "idx_lineitem_shipdate",
          "operation": "block_skip"
        }
      ],
      "predicate_pushdown": [
        "l_shipdate <= '1998-09-02' applied during scan with zone map pruning"
      ],
      "parallel_scan": true,
      "notes": "Column pruning: 7 of 16 columns = 56% I/O savings. Zone maps on l_shipdate skip blocks (though 97% selectivity means limited pruning). Dictionary-encoded l_returnflag and l_linestatus enable fast integer comparisons. Thread-parallel scan with 8-16 threads."
    },
    "Q3": {
      "tables_accessed": ["customer", "orders", "lineitem"],
      "columns_needed": [
        "customer.c_custkey",
        "customer.c_mktsegment",
        "orders.o_orderkey",
        "orders.o_custkey",
        "orders.o_orderdate",
        "orders.o_shippriority",
        "lineitem.l_orderkey",
        "lineitem.l_extendedprice",
        "lineitem.l_discount",
        "lineitem.l_shipdate"
      ],
      "index_usage": [
        {
          "index": "pk_customer",
          "operation": "point_lookup"
        },
        {
          "index": "fk_orders_customer",
          "operation": "range_scan"
        },
        {
          "index": "idx_orders_orderdate",
          "operation": "block_skip"
        },
        {
          "index": "fk_lineitem_orders",
          "operation": "range_scan"
        },
        {
          "index": "idx_lineitem_shipdate",
          "operation": "block_skip"
        }
      ],
      "predicate_pushdown": [
        "c_mktsegment = 'BUILDING' during customer scan (20% selectivity)",
        "o_orderdate < '1995-03-15' during orders scan with zone map pruning (45% selectivity)",
        "l_shipdate > '1995-03-15' during lineitem scan with zone map pruning (57% selectivity)"
      ],
      "parallel_scan": true,
      "notes": "Critical join ordering: customer (filtered) -> orders (filtered) -> lineitem (filtered). Build hash table on filtered customer (~30K rows), probe with orders in parallel. Build hash on customer-orders join result, probe with lineitem in parallel. Column pruning: customer 2/8, orders 4/9, lineitem 4/16 = massive I/O savings."
    },
    "Q6": {
      "tables_accessed": ["lineitem"],
      "columns_needed": [
        "lineitem.l_shipdate",
        "lineitem.l_discount",
        "lineitem.l_quantity",
        "lineitem.l_extendedprice"
      ],
      "index_usage": [
        {
          "index": "idx_lineitem_shipdate",
          "operation": "block_skip"
        },
        {
          "index": "idx_lineitem_discount",
          "operation": "block_skip"
        },
        {
          "index": "idx_lineitem_quantity",
          "operation": "block_skip"
        }
      ],
      "predicate_pushdown": [
        "l_shipdate >= '1994-01-01' AND l_shipdate < '1995-01-01' with zone map pruning (~14% selectivity, skips 86% of blocks)",
        "l_discount BETWEEN 0.05 AND 0.07 with zone map pruning (~20% selectivity)",
        "l_quantity < 24 with zone map pruning (~46% selectivity)"
      ],
      "parallel_scan": true,
      "notes": "Maximum column pruning: 4 of 16 columns = 75% I/O savings. Multi-column zone map pruning (AND logic): blocks must pass ALL three range predicates. Expected combined selectivity ~1.3% (0.14 * 0.20 * 0.46). Sort order by l_shipdate enables near-perfect date range block skipping."
    }
  },
  "ingestion": {
    "parallel_tables": true,
    "parallel_columns": false,
    "build_indexes_during_ingest": true,
    "notes": "Multi-table parallelism: ingest nation, region, supplier, part, customer, partsupp concurrently (independent tables). Intra-table parallelism: chunk lineitem (6M rows) and orders (1.5M rows) for parallel parsing across 8-16 threads. mmap input .tbl files for zero-copy parsing. Pre-allocate column vectors based on file size estimation. Sort lineitem by l_shipdate during ingestion. Build hash indexes and zone maps during write. Target: <5 seconds for SF1."
