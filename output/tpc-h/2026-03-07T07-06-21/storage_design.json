      "estimated_rows": 59986052,
      "sort_order": ["l_shipdate ASC"],
      "block_size": 100000,
      "file_format": { "filename": "lineitem.tbl", "delimiter": "|", "trailing_delimiter": true, "column_order": ["l_orderkey","l_partkey","l_suppkey","l_linenumber","l_quantity","l_extendedprice","l_discount","l_tax","l_returnflag","l_linestatus","l_shipdate","l_commitdate","l_receiptdate","l_shipinstruct","l_shipmode","l_comment"] },
      "columns": [
        { "name": "l_orderkey",      "cpp_type": "int32_t", "semantic_type": "INTEGER",      "encoding": "plain",             "role": "join/group/filter" },
        { "name": "l_partkey",       "cpp_type": "int32_t", "semantic_type": "INTEGER",      "encoding": "plain",             "role": "join" },
        { "name": "l_suppkey",       "cpp_type": "int32_t", "semantic_type": "INTEGER",      "encoding": "plain",             "role": "join" },
        { "name": "l_linenumber",    "cpp_type": "int32_t", "semantic_type": "INTEGER",      "encoding": "plain",             "role": "payload" },
        { "name": "l_quantity",      "cpp_type": "int8_t",  "semantic_type": "DECIMAL(15,2)","encoding": "int8_integer_value","role": "filter/agg", "note": "actual values 1-50 (whole numbers), stored as int8" },
        { "name": "l_extendedprice", "cpp_type": "double",  "semantic_type": "DECIMAL(15,2)","encoding": "plain_double",      "role": "agg" },
        { "name": "l_discount",      "cpp_type": "int8_t",  "semantic_type": "DECIMAL(15,2)","encoding": "int8_hundredths",   "role": "filter/agg", "note": "values 0.00-0.10 stored as 0-10 (multiply by 100)" },
        { "name": "l_tax",           "cpp_type": "int8_t",  "semantic_type": "DECIMAL(15,2)","encoding": "int8_hundredths",   "role": "agg",        "note": "values 0.00-0.08 stored as 0-8 (multiply by 100)" },
        { "name": "l_returnflag",    "cpp_type": "int8_t",  "semantic_type": "CHAR(1)",      "encoding": "dict_int8",         "role": "group/order", "dict": {"A":0,"N":1,"R":2}, "dict_file": "lineitem/l_returnflag_dict.bin" },
        { "name": "l_linestatus",    "cpp_type": "int8_t",  "semantic_type": "CHAR(1)",      "encoding": "dict_int8",         "role": "group/order", "dict": {"F":0,"O":1}, "dict_file": "lineitem/l_linestatus_dict.bin" },
        { "name": "l_shipdate",      "cpp_type": "int32_t", "semantic_type": "DATE",         "encoding": "days_since_epoch",  "role": "filter/sort_key" },
        { "name": "l_commitdate",    "cpp_type": "int32_t", "semantic_type": "DATE",         "encoding": "days_since_epoch",  "role": "payload" },
        { "name": "l_receiptdate",   "cpp_type": "int32_t", "semantic_type": "DATE",         "encoding": "days_since_epoch",  "role": "payload" }
      ],
      "indexes": [
        {
          "name": "l_shipdate_zone_map",
          "type": "zone_map",
          "columns": ["l_shipdate"],
          "file": "lineitem/l_shipdate_zone_map.bin",
          "layout": "header:{uint32_t num_blocks, uint32_t block_size} + blocks:{int32_t min_date, int32_t max_date}",
          "note": "Enables block-skip for Q6 (1.9% selectivity), Q3 (54.5% pass), Q1 (98.5% pass)"
        }
      ],
      "rationale": "Sorted by l_shipdate enables zone maps; int8 encoding for quantity/discount/tax saves 8x space vs double (480MB→60MB each), critical for 60M-row table. dict encoding for returnflag/linestatus enables direct integer GROUP BY (4 groups total)."
    },
