  "io_strategies": {
    "Q1": {
      "tables_accessed": ["lineitem"],
      "columns_needed": [
        "lineitem.l_shipdate",
        "lineitem.l_returnflag",
        "lineitem.l_linestatus",
        "lineitem.l_quantity",
        "lineitem.l_extendedprice",
        "lineitem.l_discount",
        "lineitem.l_tax"
      ],
      "index_usage": [
        {
          "index": "zone_l_shipdate",
          "operation": "block_skip"
        }
      ],
      "predicate_pushdown": ["l_shipdate <= date '1998-09-01'"],
      "parallel_scan": true,
      "notes": "Full scan with date filter. Zone map on l_shipdate (sorted) enables block skipping. Predicate highly selective (98% of data passes), but block-level pruning can skip future blocks if data sorted descending. Parallel scan with 64-way parallelism. Access only 7 of 16 columns (56% I/O reduction)."
    },
    "Q6": {
      "tables_accessed": ["lineitem"],
      "columns_needed": [
        "lineitem.l_shipdate",
        "lineitem.l_discount",
        "lineitem.l_quantity",
        "lineitem.l_extendedprice"
      ],
      "index_usage": [
        {
          "index": "zone_l_shipdate",
          "operation": "block_skip"
        },
        {
          "index": "zone_l_discount",
          "operation": "block_skip"
        },
        {
          "index": "zone_l_quantity",
          "operation": "block_skip"
        }
      ],
      "predicate_pushdown": [
        "l_shipdate >= date '1994-01-01'",
        "l_shipdate < date '1995-01-01'",
        "l_discount BETWEEN 0.05 AND 0.07",
        "l_quantity < 24"
      ],
      "parallel_scan": true,
      "notes": "Highly selective scan. Date range filter (1 year out of 7 = 14% selectivity) combined with discount and quantity filters. Zone maps on all three filter columns enable aggressive block skipping. Since lineitem is sorted by l_shipdate, date-based zone maps are extremely effective. Access only 4 of 16 columns (75% I/O reduction). Parallel scan with morsel-driven execution."
    },
    "Q3": {
      "tables_accessed": ["customer", "orders", "lineitem"],
      "columns_needed": [
        "customer.c_custkey",
        "customer.c_mktsegment",
        "orders.o_orderkey",
        "orders.o_custkey",
        "orders.o_orderdate",
        "orders.o_shippriority",
        "lineitem.l_orderkey",
        "lineitem.l_extendedprice",
        "lineitem.l_discount",
        "lineitem.l_shipdate"
      ],
      "index_usage": [
        {
          "index": "pk_customer",
          "operation": "point_lookup"
        },
        {
          "index": "idx_o_custkey",
          "operation": "point_lookup"
        },
        {
          "index": "idx_l_orderkey",
          "operation": "point_lookup"
        },
        {
          "index": "zone_l_shipdate",
          "operation": "block_skip"
        },
        {
          "index": "zone_o_orderdate",
          "operation": "block_skip"
        }
      ],
      "predicate_pushdown": [
        "c_mktsegment = 'BUILDING'",
        "o_orderdate < date '1995-03-15'",
        "l_shipdate > date '1995-03-15'"
      ],
      "parallel_scan": true,
      "notes": "Three-way hash join. Execution strategy: (1) Scan customer, filter on c_mktsegment, build hash table on c_custkey (~30K rows). (2) Scan orders with o_orderdate filter (zone map skips blocks), probe customer hash table, build intermediate hash table on o_orderkey (~150K qualifying orders). (3) Scan lineitem with l_shipdate filter (zone map skips blocks), probe orders hash table. All scans are parallel. Column pruning: customer uses 2/8 cols, orders uses 4/9 cols, lineitem uses 4/16 cols. Hash indexes enable efficient join probing."
    }
  },
  "ingestion": {
    "parallel_tables": true,
    "parallel_columns": false,
    "chunk_based_parallel_parsing": true,
    "build_indexes_during_ingest": true,
    "mmap_input_files": true,
    "pre_allocate_vectors": true,
    "buffered_binary_writes": true,
    "estimated_ingestion_time_seconds": 45,
    "notes": "Ingest all 8 tables in parallel (nation, region, supplier, part, partsupp, customer, orders, lineitem). For lineitem (6M rows), use chunk-based parallel parsing: split mmap'd buffer into 64 chunks, parse in parallel, concatenate. Sort lineitem by l_shipdate after parsing. Build zone maps during ingestion. Pre-allocate column vectors based on file size estimate. Use 1MB write buffers. Expected ingestion time for SF1: <45 seconds total (parsing ~30s + sorting lineitem ~10s + index building ~5s)."
  },
  "type_mappings": {
    "INTEGER": "int32_t",
