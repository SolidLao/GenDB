    "composite_key_formula": "int64_t k = ((int64_t)col1[i] << 32) | (uint32_t)col2[i]",
    "empty_slot_sentinel": "key = INT32_MIN or INT64_MIN",
    "hash_fn": "(uint64_t)(uint32_t)key * 0x9E3779B97F4A7C15ULL >> 32, masked to (ht_size-1)",
