  "type_mappings": {
    "INTEGER": "int32_t",
    "DECIMAL": "double",
    "DATE":    "int32_t",
    "CHAR":    "int8_t (raw_char or dict code) or char[N] for output strings",
    "VARCHAR": "char[N] fixed-width for output strings; int8_t dict code for filter-only"
  },
  "_note_decimal": "DECIMAL stored as double. Aggregation tolerance of small float errors acceptable for this workload (no cent-exact regulatory requirement).",
  "date_encoding": "days_since_epoch_1970. Formula: Howard Hinnant proleptic Gregorian. Self-test: parse(1970-01-01)=0.",
  "_note_raw_char": "raw_char encoding: single-char string stored as its ASCII value in int8_t. E.g. l_returnflag 'A'=65,'N'=78,'R'=82. No dict file needed. Compare with character literals in query code.",
  "_note_fixed_char": "fixed_char26/fixed_char56: null-padded fixed-width char array. File size = N_rows * char_width. Access row i: &col[i * char_width].",
  "index_formats": {
    "zone_map": "[uint32_t num_blocks][{int32_t min, int32_t max, uint32_t block_size} x num_blocks]. row_offset = block_idx * BLOCK_SIZE.",
    "hash_int32": "[uint32_t num_positions][uint32_t positions[num_positions]][uint32_t capacity][{int32_t key, uint32_t offset, uint32_t count} x capacity]. Empty slot: key==INT32_MIN.",
    "hash_int64": "[uint32_t num_positions][uint32_t positions[num_positions]][uint32_t capacity][{int64_t key, uint32_t offset, uint32_t count} x capacity]. Empty slot: key==INT64_MIN."
  },
  "hardware_config": {
