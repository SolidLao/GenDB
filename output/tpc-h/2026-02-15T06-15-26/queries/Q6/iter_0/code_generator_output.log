### **Key Implementation Features**

```cpp
// Kahan summation for precision
double sum = 0.0, c = 0.0;
#pragma omp parallel for reduction(+:sum) reduction(+:c)
for (size_t i = 0; i < num_rows; ++i) {
    // Predicates: date range, discount range, quantity < 24
    if (ship_date >= date_start && ship_date < date_end &&
        discount >= discount_min && discount <= discount_max &&
        quantity < quantity_max) {
        // Unscale product: (extprice * discount) / 10000
        double value = static_cast<double>(extendedprice * discount) / 10000.0;
        // Kahan step
        double y = value - c;
        double t = sum + y;
        c = (t - sum) - y;
        sum = t;
    }
}
```

