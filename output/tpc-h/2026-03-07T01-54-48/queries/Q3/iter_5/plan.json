{
  "query_id": "Q3",
  "pipeline": [
    "filter_dim",
    "join_fact",
    "aggregate",
    "topk"
  ],
  "join_order": [
    {
      "build": "customer(filtered: c_mktsegment='BUILDING')",
      "probe": "orders via orders_custkey_hash on o_custkey",
      "type": "inner",
      "strategy": "index_nested_loop",
      "build_cardinality": 330000,
      "notes": "Scan customer columns to build BUILDING c_custkey bitset, then probe orders_custkey_hash only for those keys and apply o_orderdate < 9204 before materializing qualifying orders."
    },
    {
      "build": "orders_after_customer_date(project: o_orderkey,o_orderdate,o_shippriority)",
      "probe": "lineitem(filtered: l_shipdate > 9204)",
      "type": "semi",
      "strategy": "direct_array",
      "build_cardinality": 1461923,
      "notes": "Create compact orderkey->group_id lookup and payload arrays for qualifying orders; lineitem stays sequential with zonemap pruning and accumulates only when lookup hits."
    }
  ],
  "filters": [
    {
      "table": "customer",
      "predicate": "c_mktsegment = 'BUILDING'",
      "selectivity": 0.22
    },
    {
      "table": "orders",
      "predicate": "o_orderdate < 9204",
      "selectivity": 0.489
    },
    {
      "table": "lineitem",
      "predicate": "l_shipdate > 9204",
      "selectivity": 0.535
    },
    {
      "table": "lineitem JOIN qualifying_orders",
      "predicate": "l_orderkey = o_orderkey",
      "selectivity": 0.0969
    }
  ],
  "scan": {
    "table": "customer+orders(index)+lineitem",
    "rows": 37400000,
    "columns": [
      {
