{
  "query_id": "Q9",
  "storage_extensions": [
    {
      "id": "orders.o_orderdate.year_dense_by_orderkey",
      "action": "use_existing",
      "files": {
        "codes": "column_versions/orders.o_orderdate.year_dense_by_orderkey/codes.bin",
        "codes_format": "int16_t[max_orderkey + 1] keyed by o_orderkey"
      },
      "usage": "mmap codes.bin once; use year_codes[o_orderkey] for o_year lookup during aggregation"
    },
    {
      "id": "part.p_name.has_green_by_partkey",
      "action": "use_existing",
      "files": {
        "codes": "column_versions/part.p_name.has_green_by_partkey/codes.bin",
        "codes_format": "uint8_t[max_partkey + 1] keyed by p_partkey; 1=contains 'green', 0=otherwise"
      },
      "usage": "mmap codes.bin once; use has_green[p_partkey] as the p_name LIKE '%green%' predicate"
    },
    {
      "id": "lineitem.l_discount.int16_scaled_by_100",
      "action": "use_existing",
      "files": {
        "codes": "column_versions/lineitem.l_discount.int16_scaled_by_100/codes.bin",
        "codes_format": "uint16_t[row_count], value=round(l_discount*100)"
      },
      "usage": "mmap codes.bin; use scaled discount codes directly in amount computation to avoid per-match floating conversion"
    },
    {
      "id": "lineitem.l_quantity.int16_scaled_by_100",
      "action": "use_existing",
      "files": {
        "codes": "column_versions/lineitem.l_quantity.int16_scaled_by_100/codes.bin",
        "codes_format": "uint16_t[row_count], value=round(l_quantity*100)"
      },
      "usage": "mmap codes.bin; use scaled quantity codes directly in amount computation to avoid per-match floating conversion"
    }
  ],
  "pipeline": [
    "filter_dim",
    "join_fact",
    "aggregate",
    "topk"
  ],
  "join_order": [
    {
      "build": "part.p_name.has_green_by_partkey(extension)",
      "probe": "partsupp(sorted by ps_partkey)",
      "type": "semi",
      "strategy": "index_nested_loop",
      "build_cardinality": 108782,
      "notes": "Enumerate qualifying partkeys from dense green lookup and fetch only matching ps_partkey ranges via lower_bound/upper_bound on sorted ps_partkey."
    },
    {
      "build": "partsupp(filtered green, key=(ps_partkey,ps_suppkey), payload=nationkey+ps_supplycost_scaled100)",
      "probe": "lineitem",
      "type": "inner",
      "strategy": "index_nested_loop",
      "build_cardinality": 435128,
      "notes": "Pack (ps_partkey,ps_suppkey) and probe pre-built lineitem_partsupp_hash to fetch matching lineitem rowids; pre-scale ps_supplycost once per filtered partsupp row and reuse for all matches."
    },
    {
      "build": "supplier+nation mappings",
      "probe": "lineitem(filtered)",
      "type": "inner",
      "strategy": "direct_array",
      "build_cardinality": 100000,
      "notes": "Precompute suppkey->nationkey and nationkey->nation_code dense arrays."
    },
    {
      "build": "orders.o_orderdate.year_dense_by_orderkey(extension)",
      "probe": "lineitem(filtered)",
      "type": "inner",
      "strategy": "direct_array",
      "build_cardinality": 60000001,
      "notes": "Lookup o_year by o_orderkey from dense extension during aggregation."
    }
  ],
  "filters": [
    {
      "table": "part",
      "predicate": "has_green[p_partkey] = 1 (equivalent to p_name LIKE '%green%')",
      "selectivity": 0.054391
    },
    {
      "table": "partsupp",
      "predicate": "ps_partkey IN green_parts",
      "selectivity": 0.054391
    }
  ],
  "scan": {
    "table": "partsupp",
    "rows": 8000000,
    "columns": [
      {
        "name": "ps_partkey",
        "file": "partsupp/ps_partkey.bin",
        "type": "int32_t",
        "bytes_per_row": 4
      },
      {
        "name": "ps_suppkey",
        "file": "partsupp/ps_suppkey.bin",
        "type": "int32_t",
        "bytes_per_row": 4
      },
      {
        "name": "ps_supplycost",
        "file": "partsupp/ps_supplycost.bin",
        "type": "double",
        "bytes_per_row": 8
      },
      {
        "name": "l_orderkey",
        "file": "lineitem/l_orderkey.bin",
        "type": "int32_t",
        "bytes_per_row": 4
      },
      {
        "name": "l_extendedprice",
        "file": "lineitem/l_extendedprice.bin",
        "type": "double",
        "bytes_per_row": 8
      },
      {
        "name": "l_discount_scaled100",
        "file": "column_versions/lineitem.l_discount.int16_scaled_by_100/codes.bin",
        "type": "uint16_t",
        "bytes_per_row": 2
      },
      {
        "name": "l_quantity_scaled100",
        "file": "column_versions/lineitem.l_quantity.int16_scaled_by_100/codes.bin",
        "type": "uint16_t",
        "bytes_per_row": 2
      }
    ],
    "access_pattern": "sequential"
  },
  "data_structures": {
    "dim_filter": "direct_array(part.p_name.has_green_by_partkey)",
    "fact_join": "sorted_range_lookup(ps_partkey) + pre_built_index(lineitem_partsupp_hash)",
    "aggregation": "direct_array(25x7)"
  },
  "parallelism": {
    "strategy": "morsel_driven",
    "threads": "auto(nproc)"
  },
  "indexes": [
    {
      "index": "lineitem_partsupp_hash",
      "purpose": "join_lookup"
    }
  ],
  "aggregation": "array_direct",
  "output": {
    "order_by": [
      "nation ASC",
      "o_year DESC"
    ],
    "limit": null
  },
  "execution_target": "cpp",
  "optimization_notes": "Root cause is Category C work-proportional waste inside main_scan: iter_2 still performs expensive per-match floating conversions/rounding for l_discount and l_quantity (and repeatedly redoes derivable scaling work), inflating CPU time even after selective pruning. The revised plan keeps the fast selective partsupp-driven join shape from iter_2 but removes hot-loop conversion overhead by using existing scaled int16 lineitem discount/quantity versions and pre-scaling partsupp supplycost once per filtered key, while retaining dense year lookup and direct-array aggregation.",
  "correctness_anchors": {}
}
