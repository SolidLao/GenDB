{
  "query_id": "Q9",
  "storage_extensions": [
    {
      "id": "orders.o_orderdate.year_dense_by_orderkey",
      "action": "built_new",
      "files": {
        "codes": "column_versions/orders.o_orderdate.year_dense_by_orderkey/codes.bin",
        "codes_format": "int16_t[max_orderkey + 1] keyed by o_orderkey"
      },
      "usage": "mmap codes.bin once; use year_codes[o_orderkey] to get o_year in main scan instead of rebuilding orderkey->year from orders table each run"
    }
  ],
  "pipeline": [
    "filter_dim",
    "join_fact",
    "aggregate",
    "topk"
  ],
  "join_order": [
    {
      "build": "part(filtered: p_name LIKE '%green%')",
      "probe": "partsupp",
      "type": "semi",
      "strategy": "bloom_filter",
      "build_cardinality": 96000,
      "notes": "Build green-part bitset+bloom, then keep only partsupp rows whose ps_partkey passes both filters."
    },
    {
      "build": "partsupp(filtered green, key=(ps_partkey,ps_suppkey))",
      "probe": "lineitem",
      "type": "inner",
      "strategy": "index_nested_loop",
      "build_cardinality": 384000,
      "notes": "Probe pre-built lineitem_partsupp_hash to fetch matching lineitem rowids per composite key."
    },
    {
      "build": "supplier+nation mappings",
      "probe": "lineitem(filtered)",
      "type": "inner",
      "strategy": "direct_array",
      "build_cardinality": 100000,
      "notes": "Precompute suppkey->nationkey and nationkey->nation_code direct arrays."
    },
    {
      "build": "orders.o_orderdate.year_dense_by_orderkey(extension)",
      "probe": "lineitem(filtered)",
      "type": "inner",
      "strategy": "direct_array",
      "build_cardinality": 60000001,
      "notes": "Use persisted dense year array keyed by o_orderkey; do not scan orders or extract year at runtime."
    }
  ],
  "filters": [
    {
      "table": "part",
      "predicate": "p_name LIKE '%green%'",
      "selectivity": 0.048
    },
    {
      "table": "partsupp",
      "predicate": "ps_partkey IN green_parts",
      "selectivity": 0.048
    }
  ],
  "scan": {
    "table": "partsupp",
    "rows": 8000000,
    "columns": [
      {
        "name": "ps_partkey",
        "file": "partsupp/ps_partkey.bin",
        "type": "int32_t",
        "bytes_per_row": 4
      },
      {
        "name": "ps_suppkey",
        "file": "partsupp/ps_suppkey.bin",
        "type": "int32_t",
        "bytes_per_row": 4
      },
      {
        "name": "ps_supplycost",
        "file": "partsupp/ps_supplycost.bin",
        "type": "double",
        "bytes_per_row": 8
      }
    ],
    "access_pattern": "sequential"
  },
  "data_structures": {
    "dim_filter": "bitset(2000001) + bloom_filter(1310720 bits)",
    "fact_join": "pre_built_index(lineitem_partsupp_hash) + compact_key_buffer",
    "aggregation": "direct_array(25x7)"
  },
  "parallelism": {
    "strategy": "morsel_driven",
    "threads": "auto(nproc)"
  },
  "indexes": [
    {
      "index": "lineitem_partsupp_hash",
      "purpose": "join_lookup"
    }
  ],
  "aggregation": "array_direct",
  "output": {
    "order_by": [
      "nation ASC",
      "o_year DESC"
    ],
    "limit": null
  },
  "execution_target": "cpp",
  "optimization_notes": "Root cause is a storage-level representation mismatch: runtime build_joins repeatedly scans all 15M orders and materializes a sparse orderkey->year array (cache-exceeding initialization plus per-row date extraction) even though Q9 only needs year lookup by orderkey during probes. Category E strategy: add a persistent dense year lookup extension keyed by o_orderkey and mmap it directly in execution; keep selective green-part filtering and lineitem composite-index probing unchanged, removing the recurring orders preprocessing work from hot path setup.",
  "correctness_anchors": {}
}
