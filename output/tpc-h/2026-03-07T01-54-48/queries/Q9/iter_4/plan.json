  "pipeline": [
    "filter_dim",
    "join_fact",
    "aggregate",
    "topk"
  ],
  "join_order": [
    {
      "build": "part.has_green dense lookup",
      "probe": "partsupp(sorted by ps_partkey)",
      "type": "semi",
      "strategy": "index_nested_loop",
      "build_cardinality": 108782,
      "notes": "Enumerate green partkeys from dense lookup and fetch only matching ps_partkey ranges via lower_bound/upper_bound."
    },
    {
      "build": "supplier+nation mappings",
      "probe": "partsupp(filtered green)",
      "type": "inner",
      "strategy": "direct_array",
      "build_cardinality": 100000,
      "notes": "Map ps_suppkey to nationkey once; carry nationkey with filtered partsupp rows."
    },
    {
      "build": "partsupp(filtered green, key=(ps_partkey,ps_suppkey))",
      "probe": "lineitem_partsupp_hash",
      "type": "inner",
      "strategy": "index_nested_loop",
      "build_cardinality": 435128,
      "notes": "Materialize match records {lineitem_rowid, nationkey, ps_supplycost_scaled100} from index hits, then sort by lineitem_rowid for locality."
    },
    {
      "build": "orders year dense lookup",
      "probe": "lineitem(matches sorted by rowid)",
      "type": "inner",
      "strategy": "direct_array",
      "build_cardinality": 60000001,
      "notes": "Use dense year lookup during aggregation of sorted matched lineitem rows."
    }
  ],
  "filters": [
    {
      "table": "part",
      "predicate": "has_green[p_partkey] = 1",
      "selectivity": 0.054391
    },
    {
      "table": "partsupp",
      "predicate": "ps_partkey IN green_parts",
      "selectivity": 0.054391
    }
  ],
  "scan": {
    "table": "lineitem",
